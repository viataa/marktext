{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node", "vite/client"],
    "jsx": "preserve"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "src/types/**/*.d.ts",
    "src/shared/**/*.ts",
    "src/common/**/*.ts",
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/renderer/**/*.ts",
    "test/**/*.ts",
    "electron.vite.config.ts",
    "vitest.config.ts"
  ],
  "exclude": [
    "node_modules",
    "out",
    "dist",
    "src/muya/**/*",
    "src/renderer/src/assets/symbolIcon/index.js",
    "**/*.min.json"
  ]
}
